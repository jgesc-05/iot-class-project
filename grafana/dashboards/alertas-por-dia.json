      "title": "Alertas Resueltas (7d)",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "rawSql": "SELECT count(*) AS value, now() AS time FROM alerts WHERE status = 'resolved' AND created_at > now() - interval '7 days'",
          "format": "table",
