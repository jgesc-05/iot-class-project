      "title": "Reglas Activas",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "rawSql": "SELECT count(*) AS value, now() AS time FROM alert_rules WHERE enabled = true",
          "format": "table",
          "refId": "A"
