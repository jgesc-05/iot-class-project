    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 301,
      "title": "Alertas por Dia (Ultima Semana)",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Pendientes" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Resueltas" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "id": 35,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Alertas por Dia",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "rawSql": "SELECT date_trunc('day', created_at) AS time, count(*) FILTER (WHERE status = 'pending') AS \"Pendientes\", count(*) FILTER (WHERE status = 'resolved') AS \"Resueltas\" FROM alerts WHERE created_at > now() - interval '7 days' GROUP BY 1 ORDER BY 1",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 302,
      "title": "Alertas Activas",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        }
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "id": 36,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "creada", "desc": true }] },
      "title": "Detalle de Alertas Recientes",
      "type": "table",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "rawSql": "SELECT a.created_at AS \"creada\", d.name AS \"dispositivo\", ar.measurement AS \"medicion\", a.triggered_value AS \"valor\", CONCAT(COALESCE(ar.min_threshold::text, '—'), ' ~ ', COALESCE(ar.max_threshold::text, '—')) AS \"rango\", a.status AS \"estado\" FROM alerts a JOIN alert_rules ar ON a.alert_rule_id = ar.id JOIN devices d ON ar.device_id = d.id ORDER BY a.created_at DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 303,
      "title": "Alertas por Dispositivo",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "id": 37,
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "tooltip": { "mode": "single" }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Distribucion de Alertas por Dispositivo (7d)",
      "type": "piechart",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "rawSql": "SELECT d.name AS metric, count(*) AS value FROM alerts a JOIN alert_rules ar ON a.alert_rule_id = ar.id JOIN devices d ON ar.device_id = d.id WHERE a.created_at > now() - interval '7 days' GROUP BY d.name ORDER BY count(*) DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["invernadero", "alertas"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {},
  "timezone": "America/Bogota",
  "title": "Alertas y Anomalias",
