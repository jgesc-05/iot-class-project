      "id": 33,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "title": "Total Alertas Hoy",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "timescaledb" },
          "rawSql": "SELECT count(*) AS value, now() AS time FROM alerts WHERE created_at::date = current_date",
          "format": "table",
